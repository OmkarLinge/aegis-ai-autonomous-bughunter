# Aegis AI Environment Configuration
# Copy this to .env and edit as needed

# API Server
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000

# Debug mode (adds verbose logging)
AEGIS_DEBUG=false

# Scanner settings
AEGIS_MAX_DEPTH=3
AEGIS_MAX_ENDPOINTS=200
AEGIS_REQUEST_TIMEOUT=10
AEGIS_DELAY_BETWEEN_REQUESTS=0.5
